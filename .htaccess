# ── Maintenance mode ─────────────────────────────────────────────────────────
# Para activar:   crea el archivo "maintenance.lock" en la raíz del servidor
# Para desactivar: borra ese archivo
# La página de mantenimiento (maintenance.html) nunca queda atrapada en el bucle.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_URI} !^/maintenance\.html$
  RewriteCond %{DOCUMENT_ROOT}/maintenance.lock -f
  RewriteRule ^ /maintenance.html [R=302,L]
</IfModule>
# ─────────────────────────────────────────────────────────────────────────────

# Service worker script must always be revalidated so clients pick up
# new versions (and cache-busted question data) without long delays.
<IfModule mod_headers.c>
  # Allow Google Sign-In popup to postMessage back to the opener
  Header always set Cross-Origin-Opener-Policy "same-origin-allow-popups"

  # ── Security headers ───────────────────────────────────────────────────────
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  # CSP: the app's CSS/JS are inline (so 'unsafe-inline' is required), and it
  # talks to Google Identity Services + Google Fonts. Avatars come from Google's
  # user-content CDNs over https. If Google login ever breaks after a deploy,
  # widen script-src/frame-src/connect-src here first.
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://accounts.google.com https://apis.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://accounts.google.com; frame-src 'self' https://accounts.google.com; base-uri 'self'; object-src 'none'"
  # ───────────────────────────────────────────────────────────────────────────

  <FilesMatch "^sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Long-lived cache for immutable static media (icons/images/fonts).
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Question banks are cache-busted via ?v=<count>, so they can cache for a day.
  <FilesMatch "\.json$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # The app shell must revalidate so users get UI/logic fixes promptly.
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/json "access plus 1 day"
</IfModule>
